# MIANG — production env. Copy to .env.prod and fill in. NEVER commit the real file.
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

# ── Demo seeding ──────────────────────────────────────────────────────────────
# true  → seed RBAC + a ready demo login to present the app:
#           connexion:  kevin_mba  /  miang1234   (solde 12 500 F, KYC vérifié)
# false → real deployment, no demo accounts.
SEED_TEST=true

# ── Public URL / exposure ─────────────────────────────────────────────────────
CORS_ORIGIN=https://miang.ayospush.com
FRONTEND_PORT=8091            # published on 127.0.0.1:8091 — reverse proxy in front

# ── PostgreSQL (your existing external container, e.g. principale-postgres-1) ──
# Use the dedicated `miang` database (NOT okoume — sharing it would clash schemas).
DATABASE_URL=postgresql://miang:mypassword@principale-postgres-1:5432/miang?schema=public
MIANG_DB_NETWORK=principale_default        # docker network of your Postgres container

# ── Auth / JWT (generate with: openssl rand -hex 48) ──────────────────────────
JWT_ACCESS_SECRET=replace_with_a_long_random_string
JWT_REFRESH_SECRET=replace_with_another_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── OTP delivery ──────────────────────────────────────────────────────────────
# ayospush → AyosPush WhatsApp template   ·   console → code printed to backend logs
OTP_PROVIDER=ayospush
AYOSPUSH_API_URL=https://ayospush.com/api/v1
AYOSPUSH_API_KEY=
AYOSPUSH_API_SECRET=
AYOSPUSH_PHONE_NUMBER_ID=
AYOSPUSH_TEMPLATE_NAME=otp_verification    # exact approved template; variable {{1}} = the code

# ── Mobile Money (deposits/withdrawals) ───────────────────────────────────────
MOBILE_MONEY_PROVIDER=stub                 # stub = simulate; swap for the real aggregator
PAYMENTS_WEBHOOK_SECRET=replace_with_a_random_string

# ── Web Push (optional) — generate: npx -y web-push generate-vapid-keys ───────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@ayospush.com

# ── Draw schedule (server local time): 20h00 nightly ─────────────────────────
DRAW_CRON=0 20 * * *
