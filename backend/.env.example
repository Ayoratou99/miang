# Copy to .env and fill in real values:  cp .env.example .env
# NEVER commit the real .env.

# --- App ---
NODE_ENV=development
API_PORT=3000
CORS_ORIGIN=http://localhost:4200

# --- PostgreSQL (Prisma reads DATABASE_URL directly) ---
DATABASE_URL=postgresql://miang:miang@localhost:5432/miang?schema=public

# --- Redis (cache, Socket.IO adapter, BullMQ, OTP, presence) ---
REDIS_URL=redis://localhost:6379

# --- Auth / JWT (generate with: openssl rand -hex 48) ---
JWT_ACCESS_SECRET=replace_with_a_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_another_long_random_string
JWT_REFRESH_EXPIRES_IN=7d

# --- OTP. console = print the code to logs (dev). ayospush = WhatsApp template. ---
OTP_PROVIDER=console
WHATSAPP_API_KEY=

# AyosPush WhatsApp template (OTP_PROVIDER=ayospush). Template var {{1}} = the code.
AYOSPUSH_API_URL=https://ayospush.com/api/v1
AYOSPUSH_API_KEY=
AYOSPUSH_API_SECRET=
AYOSPUSH_PHONE_NUMBER_ID=
AYOSPUSH_TEMPLATE_NAME=otp_verification

# --- Mobile Money aggregator (Airtel, Moov). stub = simulate locally. ---
MOBILE_MONEY_PROVIDER=stub
MOBILE_MONEY_API_KEY=
PAYMENTS_WEBHOOK_SECRET=dev_webhook_secret

# --- Web Push (VAPID) — generate: npx web-push generate-vapid-keys ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@miang.ga

# --- Object storage (profile photos): MinIO in dev, S3/R2 in prod ---
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=miang-media
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- Draw: cron for the nightly job at 20h00 (server local time) ---
DRAW_CRON=0 20 * * *
